{
  "name": "piskel",
  "version": "0.15.2-SNAPSHOT",
  "description": "Pixel art editor",
  "author": "Julian Descottes <julian.descottes@gmail.com>",
  "contributors": [
    "Vincent Renaudin"
  ],
  "homepage": "http://github.com/piskelapp/piskel",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "http://github.com/piskelapp/piskel.git"
  },
  "files": [
    "dest/prod",
    "misc/scripts/piskel-root"
  ],
  "bin": {
    "piskel-root": "./misc/scripts/piskel-root",
    "piskel-cli": "./cli/index.js"
  },
  "main": "./dest/prod/index.html",
  "scripts": {
    "prepare": "husky",
    "build": "npm run build:sprites && vite build && node scripts/partials.js",
    "build:sprites": "node scripts/sprite.js",
    "start": "npm run build && node scripts/serve.js",
    "start:test": "npm run build && node scripts/serve.js --test",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "build:desktop": "npm run lint && npm run build && node scripts/desktop.js",
    "build:mac": "npm run lint && npm run build && node scripts/desktop.js --platform=macos",
    "start:nw": "npm run build && nw",
    "e2e": "npx playwright test",
    "e2e:interactive": "npx playwright test --ui",
    "unit-tests": "karma start",
    "unit-tests:watch": "karma start --auto-watch --no-single-run",
    "test": "npm run unit-tests; npm run e2e",
    "test-ci": "bash ./run-test-ci.sh",
    "release": "npm run build && node ./bin/copy-to-piskel-website",
    "release-piskel-web": "npm run build && node ./bin/copy-to-piskel-web",
    "preversion": "npm run lint && npm test && npm run build",
    "postversion": "git push && git push --tags && npm publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "1.59.1",
    "@types/adm-zip": "0.5.8",
    "adm-zip": "0.5.17",
    "dateformat": "4.5.1",
    "fs-extra": "10.0.0",
    "gifuct-js": "2.1.2",
    "husky": "9.1.7",
    "jasmine-core": "3.8.0",
    "karma": "6.3.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-jasmine": "4.0.1",
    "magic-string": "0.30.21",
    "nw-builder": "4.17.5",
    "png-ts": "0.0.3",
    "puppeteer": "24.40.0",
    "rmdir": "1.2.0",
    "spritesheet-templates": "10.5.2",
    "spritesmith": "3.5.1",
    "terser": "5.46.1",
    "typescript": "5.9.3",
    "vite": "8.0.7"
  },
  "window": {
    "title": "Piskel",
    "icon": "dest/prod/logo.png",
    "toolbar": false,
    "width": 1000,
    "height": 700
  },
  "dependencies": {
    "minimist": "1.2.8"
  }
}
