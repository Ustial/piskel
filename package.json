{
  "name": "piskel",
  "version": "0.15.2-SNAPSHOT",
  "description": "Pixel art editor",
  "author": "Julian Descottes <julian.descottes@gmail.com>",
  "contributors": [
    "Vincent Renaudin"
  ],
  "homepage": "http://github.com/piskelapp/piskel",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "http://github.com/piskelapp/piskel.git"
  },
  "files": [
    "dest/prod",
    "misc/scripts/piskel-root"
  ],
  "bin": {
    "piskel-root": "./misc/scripts/piskel-root",
    "piskel-cli": "./cli/index.js"
  },
  "main": "./dest/prod/index.html",
  "scripts": {
    "dev": "grunt play",
    "prod": "grunt serve",
    "prod:test": "grunt serve-test",
    "format": "grunt eslint --fix",
    "preversion": "grunt test build",
    "release": "grunt && node ./bin/copy-to-piskel-website",
    "release-piskel-web": "grunt && node ./bin/copy-to-piskel-web",
    "build:desktop": "grunt desktop",
    "build:mac": "grunt desktop-mac",
    "start:nw": "grunt build && nw",
    
    "e2e": "npx playwright test",
    "e2e:interactive": "npx playwright test --ui",
    "unit-tests": "karma start",
    "unit-tests:watch": "karma start --auto-watch --no-single-run",
    "test": "npm run unit-tests; npm run e2e",    
    "test-ci": "bash ./run-test-ci.sh",
    "postversion": "git push && git push --tags && npm publish",

    "vite:sprite": "node scripts/sprite.js",
    "vite:build": "npm run vite:sprite && vite build && node scripts/partials.js",
    "vite:start": "npm run vite:build && node scripts/serve.js",
    "vite:test-server": "npm run vite:build && node scripts/serve.js --test",
    "vite:release": "npm run vite:build && node ./bin/copy-to-piskel-website",
    "vite:release-piskel-web": "npm run vite:build && node ./bin/copy-to-piskel-web",
    "vite:lint": "eslint src/js --ignore-pattern '**/lib/**'",
    "vite:lint:fix": "eslint src/js --ignore-pattern '**/lib/**' --fix",
    "vite:desktop": "npm run vite:lint && npm run vite:build && node scripts/desktop.js",
    "vite:desktop:mac": "npm run vite:lint && npm run vite:build && node scripts/desktop.js --platform=macos",
    "vite:desktop:mac-old": "npm run vite:lint && npm run vite:build && node scripts/desktop.js --platform=macos-old",
    "vite:start:nw": "npm run vite:build && nw",
    "vite:preversion": "npm run vite:lint && npm test && npm run vite:build"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.16",
    "dateformat": "4.5.1",
    "fs-extra": "10.0.0",
    "gifuct-js": "^2.1.2",
    "grunt": "1.6.1",
    "grunt-cli": "^1.4.3",
    "grunt-contrib-clean": "2.0.0",
    "grunt-contrib-concat": "1.0.1",
    "grunt-contrib-connect": "3.0.0",
    "grunt-contrib-copy": "1.0.0",
    "grunt-contrib-jshint": "3.0.0",
    "grunt-contrib-uglify": "5.0.1",
    "grunt-contrib-watch": "^1.1.0",
    "grunt-eslint": "23.0.0",
    "grunt-include-replace": "5.0.0",
    "grunt-jscs": "3.0.1",
    "grunt-karma": "4.0.2",
    "grunt-leading-indent": "0.2.0",
    "grunt-nw-builder": "4.13.0",
    "grunt-replace": "2.0.2",
    "grunt-spritesmith": "^6.9.0",
    "jasmine-core": "3.8.0",
    "karma": "6.3.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-jasmine": "4.0.1",
    "load-grunt-tasks": "5.1.0",
    "magic-string": "^0.30.21",
    "png-ts": "^0.0.3",
    "puppeteer": "^24.10.0",
    "rmdir": "1.2.0",
    "spritesheet-templates": "^10.5.2",
    "spritesmith": "^3.5.1",
    "terser": "^5.46.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.3"
  },
  "window": {
    "title": "Piskel",
    "icon": "dest/prod/logo.png",
    "toolbar": false,
    "width": 1000,
    "height": 700
  },
  "dependencies": {
    "minimist": "^1.2.5"
  }
}
